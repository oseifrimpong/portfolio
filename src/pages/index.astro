---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { href: '#about', label: 'about' },
  { href: '#systems', label: 'systems' },
  { href: '#projects', label: 'projects' },
  { href: '#ai', label: 'AI systems' },
  { href: '#consulting', label: 'consulting' },
  { href: '#contact', label: 'contact' },
];

const skills = {
  backend: ['Golang', 'Java (Spring Boot)'],
  architecture: ['Microservices', 'Domain Driven Design', 'Distributed Systems', 'API Architecture'],
  infrastructure: ['AWS', 'Cloud Architectures', 'Scalable Backend Services'],
  data: ['MySQL', 'Event Driven Systems'],
  ai: ['LLM Applications', 'AI Agents', 'RAG Systems', 'AI Data Pipelines'],
};

const projects = [
  {
    name: 'SmartProof',
    description: 'AI-powered proofreading agent that analyzes written content and improves clarity using LLM orchestration.',
    highlights: ['LLM orchestration pipeline', 'Content analysis engine', 'Real-time suggestions API'],
    tags: ['AI', 'LLM', 'Go'],
  },
  // {
  //   name: 'Shepherd',
  //   description: 'Sports analytics data pipeline that processes football match data, calculates betting metrics, and delivers insights through APIs.',
  //   highlights: ['High-volume data ingestion', 'Real-time analytics engine', 'RESTful insights API'],
  //   tags: ['Data Pipeline', 'Analytics', 'APIs'],
  // },
  // {
  //   name: 'SmartComply',
  //   description: 'A compliance platform for businesses operating in the UAE to help them stay compliant with local regulations.',
  //   highlights: ['Regulatory rule engine', 'Automated compliance checks', 'Multi-tenant SaaS'],
  //   tags: ['Compliance', 'SaaS', 'UAE'],
  // },
  {
    name: 'AI URL Shortener',
    description: 'A Go-based URL shortener that summarizes target pages and displays a branded summary before redirecting users.',
    highlights: ['AI page summarization', 'Branded redirect pages', 'High-throughput link resolution'],
    tags: ['Go', 'AI', 'Web'],
  },
];

const aiCapabilities = [
  { label: 'LLM-powered applications', icon: '⚡' },
  { label: 'AI agents & orchestration', icon: '🤖' },
  { label: 'RAG systems', icon: '🔍' },
  { label: 'AI-assisted developer tools', icon: '🛠' },
  { label: 'AI data pipelines', icon: '📊' },
  { label: 'AI-powered APIs', icon: '🔌' },
];

const consultingAreas = [
  'Backend architecture design',
  'AI system architecture',
  'Microservices system design',
  'API platform architecture',
  'Payment gateway integrations',
  'Legacy system modernization',
];
---

<Layout
  title="Obed Osei Frimpong — Backend & AI Systems Engineer"
  description="Senior backend engineer specializing in distributed systems, fintech infrastructure, and AI-powered applications."
>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-(--color-bg)/80 backdrop-blur-md border-b border-(--color-border)">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="#" class="font-mono text-sm font-(--font-mono) text-(--color-accent) hover:text-(--color-text) transition-colors">
        ~/obed
      </a>
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-mono text-xs text-(--color-muted) hover:text-(--color-accent) transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
      <button
        id="menu-toggle"
        class="md:hidden text-(--color-muted) hover:text-(--color-accent) transition-colors"
        aria-label="Toggle menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-(--color-border) bg-(--color-bg)/95 backdrop-blur-md">
      <div class="px-6 py-4 flex flex-col gap-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-link font-mono text-sm text-(--color-muted) hover:text-(--color-accent) transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-6">

    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="min-h-screen flex flex-col justify-center pt-14">
      <div class="fade-in">
        <p class="font-mono text-sm text-(--color-muted) mb-4">
          <span class="text-(--color-accent)">~$</span> whoami
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-3">
          Obed Osei Frimpong<span class="text-(--color-accent) cursor-blink">_</span>
        </h1>
        <p class="font-mono text-base sm:text-lg text-(--color-accent) mb-6">
          Senior Backend &amp; AI Systems Engineer
        </p>
        <p class="text-lg sm:text-xl text-(--color-muted) max-w-2xl mb-8 leading-relaxed">
          I design and build scalable backend systems, fintech infrastructure, and AI-powered platforms.
        </p>
        <p class="font-mono text-sm text-(--color-dim) mb-10">
          <span class="text-(--color-accent)">location:</span> Abu Dhabi, UAE
        </p>
      </div>

      <!-- Terminal snippet -->
      <div class="fade-in max-w-lg" style="animation-delay: 0.2s;">
        <div class="border border-(--color-border) rounded-lg overflow-hidden bg-(--color-card)">
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-(--color-border)">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
            <span class="font-mono text-[11px] text-(--color-dim) ml-2">systems_i_build()</span>
          </div>
          <div class="p-4 font-mono text-sm leading-relaxed">
            <p class="text-(--color-dim) mb-2"># output:</p>
            <p class="text-(--color-text)"><span class="text-(--color-accent)">-&gt;</span> high-throughput APIs</p>
            <p class="text-(--color-text)"><span class="text-(--color-accent)">-&gt;</span> fintech infrastructure</p>
            <p class="text-(--color-text)"><span class="text-(--color-accent)">-&gt;</span> distributed services</p>
            <p class="text-(--color-text)"><span class="text-(--color-accent)">-&gt;</span> microservices platforms</p>
            <p class="text-(--color-text)"><span class="text-(--color-accent)">-&gt;</span> AI-powered systems</p>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 flex justify-center fade-in" style="animation-delay: 0.4s;">
        <a href="#about" class="text-(--color-dim) hover:text-(--color-accent) transition-colors" aria-label="Scroll to about section">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M10 3v14M4 11l6 6 6-6" />
          </svg>
        </a>
      </div>
    </section>

    <!-- ═══════════════ ABOUT ═══════════════ -->
    <section id="about" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">01 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">about_me</h2>
      </header>
      <div class="max-w-3xl space-y-5 text-(--color-muted) leading-relaxed">
        <p>
          I am a software engineer based in Abu Dhabi with over a decade of experience designing and building scalable backend systems.
        </p>
        <p>
          My work focuses on backend architecture, distributed systems, and fintech infrastructure. I have extensive experience building high-performance services using Go and Java, designing microservices platforms, and integrating AI capabilities into modern applications.
        </p>
        <p>
          I enjoy solving complex engineering problems and building systems that are reliable, scalable, and simple.
        </p>
      </div>

      <!-- Tech stack badges -->
      <div class="mt-10 flex flex-wrap gap-2">
        {['Golang', 'Java', 'Spring Boot', 'Microservices', 'AWS', 'MySQL', 'REST APIs', 'gRPC', 'LLM', 'AI Agents'].map((tech) => (
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-(--color-border) text-(--color-muted) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">
            {tech}
          </span>
        ))}
      </div>
    </section>

    <!-- ═══════════════ SYSTEMS THINKING ═══════════════ -->
    <section id="systems" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">02 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">how_i_build_systems</h2>
      </header>

      <div class="max-w-3xl mb-12">
        <p class="text-(--color-muted) leading-relaxed mb-8">
          My engineering approach focuses on designing systems that scale, remain observable, and evolve over time.
        </p>
      </div>

      <!-- Principles as terminal cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { title: 'scalability_first', desc: 'Design for growth from day one. Horizontal scaling, async processing, and stateless services.' },
          { title: 'clear_boundaries', desc: 'Well-defined service boundaries with clean contracts between domains and teams.' },
          { title: 'event_driven', desc: 'Event-driven architectures that decouple services and enable real-time data flow.' },
          { title: 'observability', desc: 'Deep observability with structured logging, distributed tracing, and actionable alerts.' },
          { title: 'api_first', desc: 'API-first platforms with versioned contracts, documentation, and developer experience.' },
          { title: 'reliability', desc: 'Circuit breakers, retries, graceful degradation, and chaos-tested resilience.' },
        ].map((principle) => (
          <div class="border border-(--color-border) rounded-lg p-5 hover:border-(--color-border-hover) transition-colors bg-(--color-card) group">
            <h3 class="font-mono text-sm text-(--color-accent) mb-3 group-hover:text-(--color-text) transition-colors">
              {`> ${principle.title}`}
            </h3>
            <p class="text-sm text-(--color-muted) leading-relaxed">
              {principle.desc}
            </p>
          </div>
        ))}
      </div>

      <!-- Skills grid -->
      <div class="mt-16">
        <h3 class="font-mono text-sm text-(--color-accent) mb-6">// skills & expertise</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {Object.entries(skills).map(([category, items]) => (
            <div class="border border-(--color-border) rounded-lg p-5 hover:border-(--color-border-hover) transition-colors bg-(--color-card)">
              <h4 class="font-mono text-sm text-(--color-accent) mb-4">
                {`{${category}}`}
              </h4>
              <ul class="space-y-2">
                {items.map((item: string) => (
                  <li class="text-sm text-(--color-muted) flex items-center gap-2">
                    <span class="text-(--color-accent) text-xs">*</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ PROJECTS ═══════════════ -->
    <section id="projects" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">03 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">projects</h2>
      </header>

      <div class="grid sm:grid-cols-2 gap-6">
        {projects.map((project, i) => (
          <article class="group border border-(--color-border) rounded-lg p-6 hover:border-(--color-border-hover) transition-all bg-(--color-card) hover:bg-(--color-card-hover)">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-semibold group-hover:text-(--color-accent) transition-colors">
                {project.name}
              </h3>
              <span class="font-mono text-xs text-(--color-dim)">/{String(i + 1).padStart(2, '0')}</span>
            </div>
            <p class="text-sm text-(--color-muted) leading-relaxed mb-4">
              {project.description}
            </p>

            <!-- Engineering highlights -->
            <div class="mb-4 space-y-1">
              {project.highlights.map((h: string) => (
                <p class="font-mono text-xs text-(--color-dim)">
                  <span class="text-(--color-accent)">-&gt;</span> {h}
                </p>
              ))}
            </div>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag: string) => (
                <span class="font-mono text-[11px] px-2 py-0.5 rounded bg-(--color-accent-dim) text-(--color-accent)">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ═══════════════ AI SYSTEMS ═══════════════ -->
    <section id="ai" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">04 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">ai_systems</h2>
      </header>

      <div class="max-w-3xl mb-12">
        <p class="text-(--color-muted) leading-relaxed mb-4">
          I design and build AI-powered systems that integrate large language models into real-world applications. My focus is on production-ready AI platforms — not demos.
        </p>
      </div>

      <!-- AI terminal block -->
      <div class="max-w-2xl mb-12">
        <div class="border border-(--color-border) rounded-lg overflow-hidden bg-(--color-card)">
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-(--color-border)">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
            <span class="font-mono text-[11px] text-(--color-dim) ml-2">ai_capabilities()</span>
          </div>
          <div class="p-4 font-mono text-sm leading-loose">
            {aiCapabilities.map((cap) => (
              <p class="text-(--color-text)">
                <span class="text-(--color-accent)">-&gt;</span> {cap.label}
              </p>
            ))}
          </div>
        </div>
      </div>

      <!-- AI philosophy -->
      <div class="max-w-3xl border-l-2 border-(--color-accent) pl-6">
        <p class="text-(--color-muted) leading-relaxed italic">
          "I believe AI engineering is backend engineering — the same principles of scalability, reliability, and clean architecture apply. The model is just another service in the system."
        </p>
      </div>
    </section>

    <!-- ═══════════════ CONSULTING ═══════════════ -->
    <section id="consulting" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">05 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">work_with_me</h2>
      </header>

      <div class="max-w-3xl mb-12">
        <p class="text-(--color-muted) leading-relaxed mb-8">
          I work with startups and engineering teams to design and build scalable backend and AI systems.
        </p>
        <div class="grid sm:grid-cols-2 gap-3 font-mono text-sm">
          {consultingAreas.map((area) => (
            <p class="text-(--color-muted)">
              <span class="text-(--color-accent)">-&gt;</span> {area}
            </p>
          ))}
        </div>
      </div>

      <!-- Contact form -->
      <div class="border border-(--color-border) rounded-lg p-6 sm:p-8 bg-(--color-card) max-w-2xl">
        <h3 class="font-mono text-sm text-(--color-accent) mb-6">// book a consultation</h3>
        <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block font-mono text-xs text-(--color-dim) mb-2">name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-(--color-bg) border border-(--color-border) rounded-md px-4 py-2.5 text-sm text-(--color-text) placeholder:text-(--color-dim) focus:border-(--color-accent) focus:outline-none transition-colors"
                placeholder="John Doe"
              />
            </div>
            <div>
              <label for="email" class="block font-mono text-xs text-(--color-dim) mb-2">email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-(--color-bg) border border-(--color-border) rounded-md px-4 py-2.5 text-sm text-(--color-text) placeholder:text-(--color-dim) focus:border-(--color-accent) focus:outline-none transition-colors"
                placeholder="john@company.com"
              />
            </div>
          </div>
          <div>
            <label for="company" class="block font-mono text-xs text-(--color-dim) mb-2">company</label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full bg-(--color-bg) border border-(--color-border) rounded-md px-4 py-2.5 text-sm text-(--color-text) placeholder:text-(--color-dim) focus:border-(--color-accent) focus:outline-none transition-colors"
              placeholder="Acme Inc."
            />
          </div>
          <div>
            <label for="message" class="block font-mono text-xs text-(--color-dim) mb-2">project_description</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full bg-(--color-bg) border border-(--color-border) rounded-md px-4 py-2.5 text-sm text-(--color-text) placeholder:text-(--color-dim) focus:border-(--color-accent) focus:outline-none transition-colors resize-none"
              placeholder="Tell me about your project..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="font-mono text-sm bg-(--color-accent) text-(--color-bg) px-6 py-2.5 rounded-md hover:opacity-90 transition-opacity font-medium cursor-pointer"
          >
            send_message()
          </button>
        </form>
      </div>
    </section>

    <!-- ═══════════════ CONTACT ═══════════════ -->
    <section id="contact" class="py-24 scroll-mt-20 reveal">
      <header class="mb-12">
        <p class="font-mono text-sm text-(--color-accent) mb-2">06 //</p>
        <h2 class="text-2xl sm:text-3xl font-bold">links</h2>
      </header>

      <div class="flex flex-wrap gap-4">
        <a
          href="https://linkedin.com/in/oseifrimpong"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 border border-(--color-border) rounded-lg px-5 py-3 hover:border-(--color-accent) transition-colors bg-(--color-card)"
        >
          <svg class="w-5 h-5 text-(--color-muted) group-hover:text-(--color-accent) transition-colors" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="font-mono text-sm text-(--color-muted) group-hover:text-(--color-accent) transition-colors">LinkedIn</span>
        </a>

        <a
          href="https://github.com/oseifrimpong"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 border border-(--color-border) rounded-lg px-5 py-3 hover:border-(--color-accent) transition-colors bg-(--color-card)"
        >
          <svg class="w-5 h-5 text-(--color-muted) group-hover:text-(--color-accent) transition-colors" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          <span class="font-mono text-sm text-(--color-muted) group-hover:text-(--color-accent) transition-colors">GitHub</span>
        </a>

        <a
          href="mailto:obedosei@gmail.com"
          class="group flex items-center gap-3 border border-(--color-border) rounded-lg px-5 py-3 hover:border-(--color-accent) transition-colors bg-(--color-card)"
        >
          <svg class="w-5 h-5 text-(--color-muted) group-hover:text-(--color-accent) transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="font-mono text-sm text-(--color-muted) group-hover:text-(--color-accent) transition-colors">Email</span>
        </a>

        <a
          href="https://drive.google.com/file/d/1SyxD-IzBjIznPKK8MBrv6ie6J6oigTYS/view?usp=drive_link"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 border border-(--color-border) rounded-lg px-5 py-3 hover:border-(--color-accent) transition-colors bg-(--color-card)"
        >
          <svg class="w-5 h-5 text-(--color-muted) group-hover:text-(--color-accent) transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span class="font-mono text-sm text-(--color-muted) group-hover:text-(--color-accent) transition-colors">Resume</span>
        </a>
      </div>
    </section>
  </main>

  <!-- ═══════════════ FOOTER ═══════════════ -->
  <footer class="border-t border-(--color-border) mt-12">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-(--color-dim)">
        &copy; {new Date().getFullYear()} Obed Osei Frimpong
      </p>
      <p class="font-mono text-xs text-(--color-dim)">
        Built with curiosity and caffeine.
      </p>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
    document.querySelectorAll('.mobile-link').forEach((link) => {
      link.addEventListener('click', () => menu?.classList.add('hidden'));
    });

    // Scroll-triggered fade-in
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // Active nav highlighting
    const sections = document.querySelectorAll('section[id]');
    const navLinksEl = document.querySelectorAll('nav a[href^="#"]');
    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach((s) => {
        if (scrollY >= (s as HTMLElement).offsetTop - 200) {
          current = s.id;
        }
      });
      navLinksEl.forEach((link) => {
        link.classList.toggle('!text-[var(--color-accent)]', link.getAttribute('href') === `#${current}`);
      });
    });
  </script>
</Layout>
